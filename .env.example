# Supabase
DATABASE_URL=postgresql+asyncpg://postgres:<password>@<host>:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=media

# Encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=

# App
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# Phase 6 — multi-tenancy auth
# JWT secret: Supabase → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# Deploy — Render API key (get at: https://dashboard.render.com/u/settings#api-keys)
RENDER_API_KEY=

# Internal cron trigger secret — any random string, same value in GitHub secret INTERNAL_SECRET
# generate: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_SECRET=

# Phase 1+ (leave empty until phase)
VK_ACCESS_TOKEN=
TG_API_ID=
TG_API_HASH=
TG_SESSION_STRING=

# Phase 3 — Instagram (Business/Creator account + linked FB Page required)
# access_token: long-lived user token, scope: instagram_basic,instagram_content_publish,instagram_manage_insights
IG_ACCESS_TOKEN=
IG_USER_ID=
IG_GRAPH_API_VERSION=v21.0
